# 忽略 Python 編譯檔
__pycache__/
*.pyc

# 忽略虛擬環境
venv/
.env

# 忽略生成的資料庫 (因為每次都可以由 Excel 重建)
*.db

# 忽略 LOINC 官方資料（檔案太大且有授權限制）
fhir-code/loinc/Loinc.csv
fhir-code/loinc/LOINC_*.zip
fhir-code/loinc/*.txt

# 保留 LOINC 台灣設定檔（輕量，納入版控）
!fhir-code/loinc/taiwan_mapping.csv
!fhir-code/loinc/lab_reference_ranges.csv

# 忽略作業系統縮圖
.DS_Store

.claude

# Ignore Codex agent marker file
.codex

# 忽略 MkDocs 構建產物（文檔源文件保留，只排除構建結果）
site/

# 忽略 MkDocs 快取
.cache/

# Ignore local dataset configuration; keep the example template in version control
config/datasets.yaml

# 忽略需授權申請的原始資料（不可再散佈，請至官方申請後自行下載）
fhir-code/snomed/
fhir-code/rxnorm/
fhir-code/umls/
fhir-code/snomed/SnomedCT_InternationalRF2_PRODUCTION_*.zip
fhir-code/rxnorm/RxNorm_full_*.zip
fhir-code/umls/umls-*-metathesaurus-full.zip
