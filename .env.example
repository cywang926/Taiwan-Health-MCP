# ===========================================
# Taiwan Health MCP Server - 環境變數配置
# ===========================================
# 複製此檔案為 .env 並根據需求修改

# -----------------------------------------
# MCP 傳輸模式配置
# -----------------------------------------
# 可選值: stdio | streamable-http | sse
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# -----------------------------------------
# PostgreSQL
# -----------------------------------------
POSTGRES_DB=taiwan_health
POSTGRES_USER=mcp
POSTGRES_PASSWORD=changeme_strong_password

# DATABASE_URL is constructed automatically by docker-compose from the above
# (routed through pgBouncer on port 6432).
# Set manually only when running outside Docker:
# DATABASE_URL=postgresql://mcp:changeme@localhost:5432/taiwan_health

# -----------------------------------------
# Redis
# -----------------------------------------
# REDIS_URL is set automatically by docker-compose.
# Set manually only when running outside Docker:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------
# Metrics (Prometheus)
# -----------------------------------------
# Prometheus /metrics endpoint port (exposed on 127.0.0.1 only).
METRICS_PORT=9090

# -----------------------------------------
# Application
# -----------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------
# Admin Console
# -----------------------------------------
# Keep disabled by default. When enabled, /admin becomes available and requires
# the configured operator credentials.
ADMIN_ENABLED=false
ADMIN_USERNAME=admin
# Supported formats:
#   sha256$<hex_digest>
#   pbkdf2_sha256$<iterations>$<salt>$<hex_digest>
# Example SHA-256 generator:
#   python -c "import hashlib; print('sha256$' + hashlib.sha256(b'change-me').hexdigest())"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=change_this_admin_session_secret
ADMIN_SESSION_TTL_MINUTES=240
ADMIN_MAX_UPLOAD_MB=512
ADMIN_WORKER_NAME=admin-worker
ADMIN_WORKER_POLL_SECONDS=3
ADMIN_HEARTBEAT_INTERVAL_SECONDS=15
ADMIN_WORKER_STALE_AFTER_SECONDS=45
# Max jobs the worker runs concurrently. Dataset imports are slotted per dataset
# (ICD/LOINC/TWCore/SNOMED can run in parallel); this caps the total to bound
# peak memory. 0 = no cap (resource slots only).
ADMIN_MAX_CONCURRENT_JOBS=5

# ===========================================================================
# SEED-ONLY DEFAULTS for external/integration systems (everything below).
# These (Ollama/embedding, MinIO, OCR, Analysis LM, TFDA, worker tuning) are
# read ONCE on first boot to seed admin.app_settings when it is empty. After
# that, manage and test them in the admin console → Settings tab; editing .env
# here has no effect on an already-seeded database. (Bootstrap vars above —
# DB/Redis/MCP/ADMIN_* — are NOT in the DB and must stay in .env.)
# ===========================================================================

# -----------------------------------------
# Embedding (Semantic / Hybrid Search)
# -----------------------------------------
# Leave OLLAMA_BASE_URL unset to disable embedding — search falls back to keyword-only.
# For Docker on Linux, use host.docker.internal when Ollama runs on the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=
# Output dimensions of the embedding model.
# Must match the vector() column size in db/schema.sql.
# If you change models, update this and re-run embeddings from the admin console (Modules → re-embed).
OLLAMA_EMBED_DIMENSIONS=
# Request timeout in seconds (large batches may need more time)
OLLAMA_EMBED_TIMEOUT=30
# Number of texts per Ollama /api/embed call
OLLAMA_EMBED_BATCH_SIZE=32

# -----------------------------------------
# MinIO (Drug Assets)
# -----------------------------------------
# Docker: use the service name — MINIO_ENDPOINT=minio:9000
# Local (outside Docker): use localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=taiwan-health-drug-assets
MINIO_SECURE=false
MINIO_PRESIGN_TTL_SECONDS=3600

# -----------------------------------------
# Drug TFDA Enrichment
# -----------------------------------------
DRUG_TFDA_BASE_URL=https://mcp.fda.gov.tw
DRUG_HTTP_TIMEOUT=30
DRUG_CRAWLER_CONCURRENCY=4

# -----------------------------------------
# Drug OCR / Analysis
# -----------------------------------------
DRUG_OCR_PROVIDER=dots_ocr
DRUG_OCR_VLLM_SERVER_IP=127.0.0.1
DRUG_OCR_VLLM_PORT=8002
DRUG_OCR_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
DRUG_OCR_PROMPT_MODE=prompt_layout_all_en
# Optional override; defaults to src/prompts/drug/prompt_layout_all_en.txt
DRUG_OCR_PROMPT_PATH=

DRUG_ANALYSIS_PROVIDER=openai
DRUG_ANALYSIS_BASE_URL=http://127.0.0.1:8001/v1
DRUG_ANALYSIS_MODEL_NAME=qwen2.5:7b
DRUG_ANALYSIS_API_KEY=0
# Optional override; defaults to src/prompts/drug/analysis_prompt.txt
DRUG_ANALYSIS_PROMPT_PATH=
DRUG_ANALYSIS_TEMPERATURE=0.1
DRUG_ANALYSIS_MAX_TOKENS=4096
DRUG_ANALYSIS_MAX_RETRIES=3

# -----------------------------------------
# Dataset Configuration
# -----------------------------------------
# Optional. When set, the data-loader reads dataset locations from this file
# instead of relying only on the built-in FHIR_CODE_DIR layout.
# If unset, the loader falls back to the legacy /app/fhir-code conventions.
DATASETS_CONFIG=/app/config/datasets.yaml
